@model IEnumerable<EventHorizon.Models.ContactMessage>

@{
    ViewData["Title"] = "Contact Messages";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Feedback & Messages</h2>
        
        <div class="section-card p-4">
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    No messages received yet.
                </div>
            }
            else
            {
                <table class="table table-dark" style="background-color: var(--surface);">
                    <thead>
                        <tr>
                            <th class="text-light" style="width: 20%;">Date</th>
                            <th class="text-light" style="width: 20%;">Name</th>
                            <th class="text-light" style="width: 20%;">Email</th>
                            <th class="text-light" style="width: 30%;">Message</th>
                            <th class="text-light" style="width: 10%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="text-light small">@item.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td class="text-light fw-bold">@item.Name</td>
                                <td class="text-light"><a href="mailto:@item.Email" class="text-info text-decoration-none">@item.Email</a></td>
                                <td class="text-light text-wrap">@item.Message</td>
                                <td>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>
