@model EventHorizon.Models.TeamMember

@{
    ViewData["Title"] = "Delete Team Member";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Delete Team Member</h2>
        <h4 class="text-danger mb-4">Are you sure you want to delete this member?</h4>
        
        <div class="section-card p-4">
            <dl class="row text-light mb-4">
                <dt class="col-sm-2 text-primary">Name</dt>
                <dd class="col-sm-10">@Model.Name</dd>
                
                <dt class="col-sm-2 text-primary">Position</dt>
                <dd class="col-sm-10">@Model.Position</dd>
                
                <dt class="col-sm-2 text-primary">Image URL</dt>
                <dd class="col-sm-10">@(string.IsNullOrEmpty(Model.ImageUrl) ? "N/A" : Model.ImageUrl)</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>