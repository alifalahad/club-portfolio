@model EventHorizon.Models.TeamMember

@{
    ViewData["Title"] = "Edit Team Member";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Edit Team Member</h2>
        
        <div class="row">
            <div class="col-md-6">
                <div class="section-card p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-light"></label>
                            <input asp-for="Name" class="form-control" style="background-color: var(--bg-color); border-color: var(--border); color: white;" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Position" class="form-label fw-bold text-light"></label>
                            <input asp-for="Position" class="form-control" style="background-color: var(--bg-color); border-color: var(--border); color: white;" required />
                        </div>
                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label fw-bold text-light">Image URL (Optional)</label>
                            <input asp-for="ImageUrl" class="form-control" style="background-color: var(--bg-color); border-color: var(--border); color: white;" />
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary-custom rounded-pill">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-light rounded-pill">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>