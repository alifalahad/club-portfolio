@model EventHorizon.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<!-- Index page specific styles -->
<style>
    section {
        padding: 90px 0;
        scroll-margin-top: 70px;
    }

    .hero-bg {
        background: radial-gradient(circle at top right, #1a2a59 0%, #070b19 60%);
    }

    /* Custom scrollbar for horizontal scrolling containers */
    .overflow-auto::-webkit-scrollbar {
        height: 8px;
    }
    .overflow-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    .overflow-auto::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 4px;
    }
    .overflow-auto::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.4);
    }
</style>

<!-- 1. Hero Section -->
<div id="home" class="hero-bg py-5">
    <div class="container pt-5 pb-4">
        <div class="row align-items-center fade-up">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <h1 class="display-4 fw-bold">Welcome to Event Horizon</h1>
                <p class="lead" style="color: var(--text-soft);">Exploring the Universe Together</p>
                <a href="#events" class="btn btn-primary-custom rounded-pill px-4 py-2 mt-3">Upcoming Events</a>
            </div>
            <div class="col-lg-6">
                <!-- Astronomy placeholder image -->
                <img src="https://images.unsplash.com/photo-1502134249126-9f3755a50d78?auto=format&fit=crop&w=1000&q=80" 
                     class="img-fluid rounded border shadow-lg" 
                     style="border-color: var(--border) !important; aspect-ratio: 4/3; object-fit: cover;" 
                     alt="Stargazing Scene" />
            </div>
        </div>
    </div>
</div>

<!-- 2. About Section -->
<section id="about">
    <div class="container fade-up">
        <div class="section-card p-4 p-md-5">
            <h2 class="mb-3">About Event Horizon</h2>
            <p style="color: var(--text-soft);">
                Event Horizon is a university astronomy and stargazing club where students explore the night sky, 
                learn about space, and enjoy astronomy together in a simple and friendly way.
            </p>
            
            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="p-4 rounded h-100" style="background-color: var(--bg-color); border: 1px solid var(--border);">
                        <h4 style="color: var(--primary);">Mission</h4>
                        <p class="mb-0" style="color: var(--text-soft);">To help students learn astronomy, build curiosity about the universe, and create fun stargazing experiences on campus.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 rounded h-100" style="background-color: var(--bg-color); border: 1px solid var(--border);">
                        <h4 style="color: var(--primary);">Vision</h4>
                        <p class="mb-0" style="color: var(--text-soft);">To become a welcoming student club where anyone can explore the cosmos, share ideas, and grow a lifelong interest in space.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. Events Section -->
<section id="events" class="hero-bg border-top border-bottom" style="border-color: var(--border) !important;">
    <div class="container fade-up">
        <h2 class="mb-2">Events</h2>
        <p class="mb-4" style="color: var(--text-soft);">Here are three upcoming events for Event Horizon members.</p>
        
        <div class="d-flex flex-nowrap overflow-auto gap-4 pt-2 pb-4 px-2" style="scrollbar-width: thin; margin: 0 -0.5rem;">
            @if (Model.Events != null && Model.Events.Any())
            {
                foreach (var ev in Model.Events)
                {
                    <div style="flex: 0 0 auto; width: 320px; max-width: 85vw;">
                        <div class="section-card event-card p-4 h-100 text-wrap text-start">
                            <div class="fw-bold mb-2" style="color: var(--primary);">@ev.Date.ToString("dd MMM yyyy")</div>
                            <h5>@ev.Title</h5>
                            <p class="mb-0" style="color: var(--text-soft);">@ev.Description</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">No upcoming events scheduled yet.</div>
            }
        </div>
    </div>
</section>

<!-- 4. Team Section -->
<section id="team">
    <div class="container fade-up">
        <h2 class="mb-2">Team</h2>
        <p class="mb-4" style="color: var(--text-soft);">Meet the executive members who organize Event Horizon activities.</p>

        <div class="d-flex flex-nowrap overflow-auto gap-4 pt-2 pb-4 px-2 text-center" style="scrollbar-width: thin; margin: 0 -0.5rem;">
            @if (Model.TeamMembers != null && Model.TeamMembers.Any())
            {
                foreach (var member in Model.TeamMembers.OrderByDescending(m => m.IsPresident))
                {
                    <div style="flex: 0 0 auto; width: 250px; max-width: 75vw;">
                        <div class="section-card team-card p-4 h-100 text-wrap" style="@(member.IsPresident ? "border-color: gold; box-shadow: 0 0 18px rgba(255,215,0,0.25);" : "")">
                            @if (member.IsPresident)
                            {
                                <div class="mb-1" style="font-size:1.3rem;">&#128081;</div>
                            }
                            @if (!string.IsNullOrEmpty(member.ImageUrl))
                            {
                                <img src="@member.ImageUrl" alt="@member.Name" class="team-avatar mb-3"
                                     style="object-fit:cover;padding:0;border-width:2px;@(member.IsPresident ? "border-color:gold;" : "")" />
                            }
                            else
                            {
                                <div class="team-avatar mb-3" style="@(member.IsPresident ? "border-color:gold;background:linear-gradient(135deg,#7a5c00,#2a1f00);" : "")">&#9733;</div>
                            }
                            <h5 class="mb-1">@member.Name</h5>
                            <div class="small fw-bold" style="color:@(member.IsPresident ? "gold" : "var(--primary)")">@member.Position</div>
                            @if (!string.IsNullOrEmpty(member.Description))
                            {
                                <p class="small mt-2 mb-0" style="color: var(--text-soft); font-size: 0.8rem;">@member.Description</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-3">
                    No team members yet.
                    <a asp-controller="TeamMembers" asp-action="Create" style="color:var(--primary);">Add the first member &rarr;</a>
                </div>
            }
        </div>
    </div>
</section>

<!-- 5. Contact Section -->
<section id="contact">
    <div class="container fade-up">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="section-card p-4 p-md-5">
                    <h2 class="mb-3">Contact</h2>
                    <p style="color: var(--text-soft);">Send us a message if you want to join Event Horizon or ask about upcoming activities.</p>
                    
                    <form action="#" method="post" class="mt-4">
                        <div class="mb-3">
                            <label for="name" class="form-label fw-bold">Name</label>
                            <input type="text" class="form-control text-light" id="name" style="background-color: var(--bg-color); border-color: var(--border);" placeholder="Your full name" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control text-light" id="email" style="background-color: var(--bg-color); border-color: var(--border);" placeholder="your@email.com" required>
                        </div>
                        <div class="mb-4">
                            <label for="message" class="form-label fw-bold">Message</label>
                            <textarea class="form-control text-light" id="message" rows="5" style="background-color: var(--bg-color); border-color: var(--border);" placeholder="Write your message here..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary-custom rounded-pill px-5">Submit</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>