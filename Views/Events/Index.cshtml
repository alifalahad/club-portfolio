@model IEnumerable<EventHorizon.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Manage Events</h2>
        
        <p>
            <a asp-action="Create" class="btn btn-primary-custom rounded-pill">Create New Event</a>
        </p>
        
        <div class="section-card p-4">
            <table class="table table-dark" style="background-color: var(--surface);">
                <thead>
                    <tr>
                        <th class="text-light">Title</th>
                        <th class="text-light">Date</th>
                        <th class="text-light">Description</th>
                        <th class="text-light">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="text-light">@item.Title</td>
                            <td class="text-light">@item.Date.ToShortDateString()</td>
                            <td class="text-light">@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-info text-decoration-none">Edit</a> |
                                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>