@model EventHorizon.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Delete Event</h2>
        <h4 class="text-danger mb-4">Are you sure you want to delete this event?</h4>
        
        <div class="section-card p-4">
            <dl class="row text-light mb-4">
                <dt class="col-sm-2 text-primary">Title</dt>
                <dd class="col-sm-10">@Model.Title</dd>
                
                <dt class="col-sm-2 text-primary">Date</dt>
                <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>
                
                <dt class="col-sm-2 text-primary">Description</dt>
                <dd class="col-sm-10">@Model.Description</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>