@model EventHorizon.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<section class="py-5 mt-5">
    <div class="container">
        <h2 class="text-white mb-4">Create New Event</h2>
        
        <div class="row">
            <div class="col-md-6">
                <div class="section-card p-4">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold text-light"></label>
                            <input asp-for="Title" class="form-control" style="background-color: var(--bg-color); border-color: var(--border); color: white;" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Date" class="form-label fw-bold text-light"></label>
                            <input asp-for="Date" type="date" class="form-control" style="background-color: var(--bg-color); border-color: var(--border); color: white;" required />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-light"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" style="background-color: var(--bg-color); border-color: var(--border); color: white;" required></textarea>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary-custom rounded-pill">Create</button>
                            <a asp-action="Index" class="btn btn-outline-light rounded-pill">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>